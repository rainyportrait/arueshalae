{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"jsx": "react-jsx",
		"jsxImportSource": "preact",
		"lib": ["ES2021", "DOM", "DOM.Iterable"],
		"types": ["node"],
		"baseUrl": ".",
		"ignoreDeprecations": "6.0",
		"paths": {
			"*": ["node_modules/*"]
		}
	},
	"include": ["src/ui/**/*", "build-userscript.ts"]
}
